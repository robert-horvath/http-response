{
	"name" : "robert/http-response",
	"license" : "MIT",
	"require" : {
		"php" : ">=7.1"
	},
	"require-dev" : {
		"phpunit/phpunit" : "~7.3.0",
		"phan/phan" : "^1.1"
	},
	"autoload" : {
		"psr-4" : {
			"RHo\\Http\\" : "src/",
			"RHo\\Http\\Response\\" : [
				"src/informational",
				"src/successful",
				"src/redirection",
				"src/client-error",
				"src/server-error"
			]
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"RHo\\HttpTest\\" : "tests/"
		}
	},
	"scripts" : {
		"unit-test-env" : ""
	}
}